EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Mailbox credentials used to authenticate in SMTP.
EMAIL_HOST_USER=your_mailbox@example.com
EMAIL_HOST_PASSWORD=your_app_password

# Sender and admin recipient.
DEFAULT_FROM_EMAIL=your_mailbox@example.com
ADMIN_EMAIL=your_mailbox@example.com

# Optional: explicit SMTP settings.
# If omitted, settings.py auto-selects defaults by EMAIL_HOST_USER domain:
# yandex -> smtp.yandex.ru:465 SSL
# mail.ru -> smtp.mail.ru:465 SSL
# gmail  -> smtp.gmail.com:587 TLS
#EMAIL_HOST=smtp.yandex.ru
#EMAIL_PORT=465
#EMAIL_USE_SSL=True
#EMAIL_USE_TLS=False
